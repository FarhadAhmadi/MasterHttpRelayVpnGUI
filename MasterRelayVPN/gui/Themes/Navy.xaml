<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Medium-navy SaaS palette: deep blue base, soft accents, no pure black. -->
    <Color x:Key="Bg">#FF1B2740</Color>
    <Color x:Key="BgGradTop">#FF223052</Color>
    <Color x:Key="BgGradBot">#FF18213A</Color>
    <Color x:Key="Surface">#FF263452</Color>
    <Color x:Key="Surface2">#FF2E3D5E</Color>
    <Color x:Key="Border">#FF394A6E</Color>
    <Color x:Key="Fg">#FFEEF1F8</Color>
    <Color x:Key="FgDim">#FFA9B4CC</Color>
    <Color x:Key="Accent">#FF4F8DF7</Color>
    <Color x:Key="AccentHi">#FF6FA3FF</Color>
    <Color x:Key="AccentLo">#FF3974D8</Color>
    <Color x:Key="Danger">#FFE65B6A</Color>
    <Color x:Key="Warn">#FFE0B054</Color>
    <Color x:Key="Ok">#FF4ECF8F</Color>

    <SolidColorBrush x:Key="BgBrush"       Color="{StaticResource Bg}"/>
    <SolidColorBrush x:Key="SurfaceBrush"  Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2}"/>
    <SolidColorBrush x:Key="BorderBrush2"  Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="FgBrush"       Color="{StaticResource Fg}"/>
    <SolidColorBrush x:Key="FgDimBrush"    Color="{StaticResource FgDim}"/>
    <SolidColorBrush x:Key="AccentBrush"   Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentHiBrush" Color="{StaticResource AccentHi}"/>
    <SolidColorBrush x:Key="DangerBrush"   Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="WarnBrush"     Color="{StaticResource Warn}"/>
    <SolidColorBrush x:Key="OkBrush"       Color="{StaticResource Ok}"/>

    <LinearGradientBrush x:Key="WindowBgBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BgGradTop}" Offset="0"/>
        <GradientStop Color="{StaticResource BgGradBot}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroIdleBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource AccentHi}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentLo}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroStopBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFEC6E7C" Offset="0"/>
        <GradientStop Color="#FFC44C5A" Offset="1"/>
    </LinearGradientBrush>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Variable"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FF000000" Opacity="0.25" BlurRadius="14" ShadowDepth="2"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgDimBrush}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style x:Key="StatBig" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="StatMed" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="HeroButton" TargetType="Button">
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="Background" Value="{StaticResource HeroIdleBrush}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Width" Value="190"/>
        <Setter Property="Height" Value="190"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse x:Name="ring" Stroke="#3FFFFFFF" StrokeThickness="3"
                                 Width="200" Height="200"/>
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="95" Width="190" Height="190">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF1B2740" Opacity="0.55"
                                                  BlurRadius="20" ShadowDepth="4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ring" Property="Stroke" Value="#7FFFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HeroButtonStop" TargetType="Button" BasedOn="{StaticResource HeroButton}">
        <Setter Property="Background" Value="{StaticResource HeroStopBrush}"/>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#FF374870"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#FF2A3A5E"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="Background" Value="#FF1F2A45"/>
        <Setter Property="CaretBrush" Value="{StaticResource FgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="9,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="Background" Value="#FF1F2A45"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Height" Value="32"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="11"/>
        <Setter Property="Height" Value="11"/>
    </Style>

</ResourceDictionary>
