<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Greenish modern theme. Dark green base + neon-mint accent. Used over the leafy background image. -->
    <Color x:Key="Bg">#FF0F1F18</Color>
    <Color x:Key="Surface">#CC102A1F</Color>          <!-- semi-transparent so background shows through -->
    <Color x:Key="Surface2">#CC1A3A2A</Color>
    <Color x:Key="Border">#FF2C5240</Color>
    <Color x:Key="Fg">#FFEAF6EE</Color>
    <Color x:Key="FgDim">#FF9FBDA8</Color>
    <Color x:Key="Accent">#FF2BD9A0</Color>            <!-- neon mint -->
    <Color x:Key="AccentHi">#FF55F0BA</Color>
    <Color x:Key="AccentLo">#FF1AA079</Color>
    <Color x:Key="Danger">#FFE76F6A</Color>
    <Color x:Key="Warn">#FFE6C25C</Color>
    <Color x:Key="Ok">#FF45D996</Color>

    <SolidColorBrush x:Key="BgBrush"       Color="{StaticResource Bg}"/>
    <SolidColorBrush x:Key="SurfaceBrush"  Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2}"/>
    <SolidColorBrush x:Key="BorderBrush2"  Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="FgBrush"       Color="{StaticResource Fg}"/>
    <SolidColorBrush x:Key="FgDimBrush"    Color="{StaticResource FgDim}"/>
    <SolidColorBrush x:Key="AccentBrush"   Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentHiBrush" Color="{StaticResource AccentHi}"/>
    <SolidColorBrush x:Key="DangerBrush"   Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="WarnBrush"     Color="{StaticResource Warn}"/>
    <SolidColorBrush x:Key="OkBrush"       Color="{StaticResource Ok}"/>

    <LinearGradientBrush x:Key="HeroIdleBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource AccentHi}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentLo}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroStopBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFEC6E7C" Offset="0"/>
        <GradientStop Color="#FFC44C5A" Offset="1"/>
    </LinearGradientBrush>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FF000000" Opacity="0.45" BlurRadius="22" ShadowDepth="3"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgDimBrush}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style x:Key="StatBig" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontSize" Value="30"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="StatMed" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Hero button: tighter padding around the circle, neon glow ring. -->
    <Style x:Key="HeroButton" TargetType="Button">
        <Setter Property="Foreground" Value="#FF062118"/>
        <Setter Property="Background" Value="{StaticResource HeroIdleBrush}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Width" Value="170"/>
        <Setter Property="Height" Value="170"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- soft outer glow ring -->
                        <Ellipse Width="190" Height="190" Fill="Transparent">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#FF2BD9A0" BlurRadius="32"
                                                  ShadowDepth="0" Opacity="0.45"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse x:Name="ring" Stroke="#55FFFFFF" StrokeThickness="2"
                                 Width="178" Height="178"/>
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="85" Width="170" Height="170">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ring" Property="Stroke" Value="#AAFFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HeroButtonStop" TargetType="Button" BasedOn="{StaticResource HeroButton}">
        <Setter Property="Background" Value="{StaticResource HeroStopBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#CC1F4A36"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#CC153328"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="#FF062118"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="ActivePresetButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="#FF062118"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="Background" Value="#CC0E2218"/>
        <Setter Property="CaretBrush" Value="{StaticResource FgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="9,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="Background" Value="#CC0E2218"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Height" Value="32"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="11"/>
        <Setter Property="Height" Value="11"/>
    </Style>

</ResourceDictionary>
