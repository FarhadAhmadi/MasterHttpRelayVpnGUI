<Window x:Class="MasterRelayVPN.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MasterRelayVPN.ViewModels"
        xmlns:m="clr-namespace:MasterRelayVPN.Models"
        xmlns:svc="clr-namespace:MasterRelayVPN.Services"
        xmlns:views="clr-namespace:MasterRelayVPN.Views"
        Title="MasterRelayVPN"
        Width="1040" Height="700"
        MinWidth="820" MinHeight="560"
        MaxWidth="1680" MaxHeight="1080"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI"
        PreviewKeyDown="Window_PreviewKeyDown"
        FlowDirection="{Binding Loc.FlowDirection}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="TabMetricCard" TargetType="Border" BasedOn="{StaticResource MetricTile}">
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style x:Key="SettingsLabel" TargetType="TextBlock" BasedOn="{StaticResource Caption}">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SettingsCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SettingsText" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="HintCard" TargetType="Border" BasedOn="{StaticResource MetricTile}">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="8"
                            Background="{StaticResource AccentBrush}" Margin="0,0,12,0">
                        <TextBlock Text="M" Foreground="#FF061711"
                                   FontSize="21" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel x:Name="TitleBlock">
                        <TextBlock Text="MasterRelayVPN" FontSize="19" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Loc[app_subtitle]}"
                                   Foreground="{StaticResource FgDimBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding DashboardBreadcrumb}"
                                   Foreground="{StaticResource FgDimBrush}" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="18,0,0,0" VerticalAlignment="Center">
                        <Button Content="Home"
                                Command="{Binding SetDashboardSectionCmd}" CommandParameter="home"
                                Padding="12,7" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DashboardSection}" Value="home">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="#FF062118"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Analytics"
                                Command="{Binding SetDashboardSectionCmd}" CommandParameter="analytics"
                                Padding="12,7" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DashboardSection}" Value="analytics">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="#FF062118"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Settings"
                                Command="{Binding SetDashboardSectionCmd}" CommandParameter="settings"
                                Padding="12,7">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DashboardSection}" Value="settings">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="#FF062118"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="StatusPillHost" Style="{StaticResource StatusPill}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding StatusFriendly}" Foreground="{Binding StatusBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Button Content="{Binding Loc.LanguageButtonLabel}"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding ToggleLanguageCmd}" Padding="14,7" Margin="0,0,8,0"/>
                    <Button Content="{Binding SysProxyActionLabel}"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding ToggleSysProxyCmd}"
                            ToolTip="{Binding SysProxyStateLabel}"
                            Padding="12,7" Margin="0,0,8,0"/>
                    <Button Content="Analyze &amp; Suggest"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding AnalyzeAndRecommendCmd}"
                            ToolTip="Review current relay/proxy state and apply tuning only (no relay removal)."
                            Padding="12,7" Margin="0,0,8,0"/>
                    <Button x:Name="WindowModeBtn" Content="Minimal"
                            Style="{StaticResource GhostButton}"
                            ToolTip="Switch between Mini and Max workspace layouts."
                            Click="WindowModeBtn_Click"
                            Padding="12,7" Margin="0,0,8,0"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DashboardSection}" Value="home">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DashboardSection}" Value="analytics">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DashboardSection}" Value="settings">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.55*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="LeftControlPanel" Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,18,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding Loc[health]}" Style="{StaticResource Caption}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Ellipse Width="11" Height="11" Fill="{Binding HealthBrush}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding HealthLabel}" FontSize="24" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding LastCheckLabel}" Foreground="{StaticResource FgDimBrush}"
                                       FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>

                        <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Button Content="{Binding HeroLabel}"
                                    Style="{StaticResource HeroButton}"
                                    Command="{Binding StartCmd}"
                                    Visibility="{Binding IsStopped, Converter={StaticResource BoolToVisible}}"/>
                            <Button Content="{Binding HeroLabel}"
                                    Style="{StaticResource HeroButtonStop}"
                                    Command="{Binding StopCmd}"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisible}}"/>
                            <Button Content="..."
                                    Style="{StaticResource HeroButton}"
                                    IsEnabled="False"
                                    Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisible}}"/>
                        </Grid>

                        <Grid x:Name="BottomStatusTiles" Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource MetricTile}" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Loc[cert]}" Style="{StaticResource Caption}"/>
                                    <TextBlock Text="{Binding CertStatus}" Foreground="{Binding CertStatusBrush}"
                                               FontWeight="SemiBold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource MetricTile}" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Loc[proxy]}" Style="{StaticResource Caption}"/>
                                    <TextBlock FontWeight="SemiBold" Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Loc[proxy_off]}"/>
                                                <Setter Property="Foreground" Value="{StaticResource FgDimBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SysProxyOn}" Value="True">
                                                        <Setter Property="Text" Value="{Binding Loc[proxy_on]}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="1" Style="{StaticResource Panel}" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Loc[activity]}" FontWeight="SemiBold"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="{Binding Loc[copy]}" Style="{StaticResource GhostButton}"
                                            Padding="8,3" Margin="0,0,4,0" Command="{Binding CopyLogsCmd}"/>
                                    <Button Content="{Binding Loc[clear]}" Style="{StaticResource GhostButton}"
                                            Padding="8,3" Command="{Binding ClearLogsCmd}"/>
                                </StackPanel>
                            </Grid>

                            <ListBox x:Name="LogList" Grid.Row="1"
                                     ItemsSource="{Binding LogsView}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Margin="0,12,0,0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.ScrollChanged="LogList_ScrollChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0,3"/>
                                        <Setter Property="Focusable" Value="False"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type m:LogEntry}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54"/>
                                                <ColumnDefinition Width="58"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Time, StringFormat=HH:mm:ss}"
                                                       Foreground="{StaticResource FgDimBrush}"
                                                       FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                                            <Border Grid.Column="1" Style="{StaticResource LogBadge}">
                                                <TextBlock Text="{Binding LevelShort}" FontSize="10"
                                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Message}"
                                                       TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <Border x:Name="PresetPanel" Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource Panel}" Padding="14" Margin="0,18,0,0">
                    <UniformGrid Columns="4">
                        <Button Margin="0,0,6,0" Padding="12,10"
                                Content="{Binding Loc[preset_stealth]}"
                                Command="{Binding ApplyPresetCmd}" CommandParameter="stealth"
                                Style="{StaticResource PresetButton}"/>
                        <Button Margin="6,0,6,0" Padding="12,10"
                                Content="{Binding Loc[preset_balanced]}"
                                Command="{Binding ApplyPresetCmd}" CommandParameter="balanced"
                                Style="{StaticResource PresetButton}"/>
                        <Button Margin="6,0,6,0" Padding="12,10"
                                Content="{Binding Loc[preset_speed]}"
                                Command="{Binding ApplyPresetCmd}" CommandParameter="speed"
                                Style="{StaticResource PresetButton}"/>
                        <Button Margin="6,0,0,0" Padding="12,10"
                                Content="{Binding Loc[preset_auto]}"
                                Command="{Binding ApplyPresetCmd}" CommandParameter="auto"
                                Style="{StaticResource PresetButton}"/>
                    </UniformGrid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Height="0"/>
        </Grid>

        <Grid Background="Transparent" Margin="0,84,0,0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DashboardSection}" Value="analytics">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <views:AnalyticsPanel Margin="18,88,18,18"/>
        </Grid>

        <Grid Background="Transparent" Margin="0,84,0,0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DashboardSection}" Value="settings">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Style="{StaticResource Panel}" Padding="22"
                    Margin="18,88,18,18"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding Loc[settings]}" FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource HintCard}">
                                <TextBlock Text="Tip: use multiple deployment IDs to spread traffic and reduce rate-limit pressure." TextWrapping="Wrap"/>
                            </Border>
                            <TextBlock Text="{Binding Loc[mode]}" Style="{StaticResource SettingsLabel}"/>
                            <ComboBox SelectedValue="{Binding Mode}" SelectedValuePath="Content" Style="{StaticResource SettingsCombo}"
                                      ToolTip="Connection backend mode. Apps Script is the default option for most users.">
                                <ComboBoxItem Content="apps_script"/>
                                <ComboBoxItem Content="google_fronting"/>
                                <ComboBoxItem Content="domain_fronting"/>
                                <ComboBoxItem Content="custom_domain"/>
                            </ComboBox>

                            <TextBlock Text="{Binding Loc[deployment_ids]}" Style="{StaticResource SettingsLabel}"/>
                            <ItemsControl ItemsSource="{Binding DeploymentIds}" Margin="0,0,0,6">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"
                                                      ToolTip="Enable or disable this relay ID without removing it."/>
                                            <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Cascadia Mono, Consolas"
                                                     ToolTip="Paste one Deployment ID per row."/>
                                            <Button Grid.Column="2" Content="-"
                                                    Style="{StaticResource GhostButton}"
                                                    Padding="0" Width="30" Height="30" Margin="6,0,0,0"
                                                    Command="{Binding DataContext.RemoveDeploymentCmd,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,14"
                                    Style="{StaticResource GhostButton}"
                                    Content="{Binding Loc[add_deployment]}"
                                    ToolTip="Add another relay/deployment ID."
                                    Command="{Binding AddDeploymentCmd}"/>

                            <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0"
                                    Margin="0,0,0,12"/>
                            <TextBlock Text="Relay Balancing" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Strategy" Style="{StaticResource SettingsLabel}"/>
                                    <ComboBox SelectedValue="{Binding MultiIdStrategy}" SelectedValuePath="Content">
                                        <ComboBoxItem Content="balanced"/>
                                        <ComboBoxItem Content="fair_spread"/>
                                        <ComboBoxItem Content="round_robin"/>
                                        <ComboBoxItem Content="least_used"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Fail threshold" Style="{StaticResource SettingsLabel}"/>
                                    <TextBox Text="{Binding MultiIdFailThreshold, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsText}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Cooldown (sec)" Style="{StaticResource SettingsLabel}"/>
                                    <TextBox Text="{Binding MultiIdCooldownSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsText}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Max consecutive per relay" Style="{StaticResource SettingsLabel}"/>
                                    <TextBox Text="{Binding MultiIdMaxConsecutive, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsText}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Balanced is recommended. Lower fail threshold reacts faster; higher cooldown keeps bad relays parked longer."
                                       Style="{StaticResource Caption}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding EnabledRelaysCountLabel, StringFormat=Enabled relay IDs: {0}}"
                                       Style="{StaticResource Caption}" Margin="0,0,0,12"/>

                            <TextBlock Text="Direct Bypass Domains" Style="{StaticResource SettingsLabel}"/>
                            <TextBox Text="{Binding DirectBypassDomainsText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsText}"
                                     AcceptsReturn="True" Height="84"
                                     VerticalScrollBarVisibility="Auto"
                                     ToolTip="Domains to skip relay and connect directly (one per line), e.g. chatgpt.com"/>
                            <TextBlock Text="Bypass is useful for Cloudflare challenge-heavy websites."
                                       Style="{StaticResource Caption}" Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding Loc[front_domain]}" Style="{StaticResource SettingsLabel}"/>
                            <TextBox Text="{Binding FrontDomain, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsText}"
                                     ToolTip="Front domain for Apps Script mode (for example: www.google.com)."/>
                            <TextBlock Text="{Binding Loc[custom_sni]}" Style="{StaticResource SettingsLabel}"/>
                            <TextBox Text="{Binding CustomSni, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsText}"
                                     ToolTip="Optional custom SNI. Leave empty unless your network requires it."/>
                            <TextBlock Text="{Binding Loc[worker_host]}" Style="{StaticResource SettingsLabel}"/>
                            <TextBox Text="{Binding WorkerHost, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsText}"
                                     ToolTip="Cloudflare Worker host, only used in worker modes."/>
                            <TextBlock Text="{Binding Loc[auth_key]}" Style="{StaticResource SettingsLabel}"/>
                            <TextBox Text="{Binding AuthKey, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Cascadia Mono, Consolas" Style="{StaticResource SettingsText}"
                                     ToolTip="Must match the secret configured in your relay backend."/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Loc[listen_host]}" Style="{StaticResource Caption}"/>
                                    <TextBox Text="{Binding ListenHost, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Local bind address, usually 127.0.0.1"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding Loc[port]}" Style="{StaticResource Caption}"/>
                                    <TextBox Text="{Binding ListenPort, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Local proxy port used by browser/apps."/>
                                </StackPanel>
                            </Grid>

                            <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0"
                                    Margin="0,8,0,12"/>
                            <TextBlock Text="{Binding Loc[network_tuning]}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="Response Cache" FontWeight="SemiBold" Margin="0,8,0,8"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="Enable cache" IsChecked="{Binding CacheEnabled}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Cache size (MB)" Style="{StaticResource SettingsLabel}"/>
                                    <TextBox Text="{Binding CacheMaxMb, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsText}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Default TTL (sec)" Style="{StaticResource SettingsLabel}"/>
                                    <TextBox Text="{Binding CacheDefaultTtlS, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsText}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Serve stale on error (sec)" Style="{StaticResource SettingsLabel}"/>
                                    <TextBox Text="{Binding CacheStaleIfErrorS, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsText}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="For best hit rate, keep cache enabled and use 300-1200s TTL for static-heavy browsing."
                                           VerticalAlignment="Center" TextWrapping="Wrap" Style="{StaticResource Caption}"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Loc[fragment]}" Style="{StaticResource Caption}"/>
                                    <TextBox Text="{Binding FragmentSize, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Packet fragment size. Smaller can improve stability on strict networks."/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding Loc[chunk]}" Style="{StaticResource Caption}"/>
                                    <TextBox Text="{Binding ChunkSize, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Chunk size for upstream transfer. Larger can improve throughput."/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{Binding Loc[parallel]}" Style="{StaticResource Caption}"/>
                                    <TextBox Text="{Binding MaxParallel, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Maximum parallel relay requests."/>
                                </StackPanel>
                            </Grid>

                            <CheckBox Content="{Binding Loc[use_chunked]}"
                                      IsChecked="{Binding EnableChunked}" Margin="0,0,0,4"/>
                            <CheckBox Content="{Binding Loc[enable_http2]}"
                                      IsChecked="{Binding EnableHttp2}" Margin="0,0,0,4"/>
                            <CheckBox Content="{Binding Loc[verify_ssl]}"
                                      IsChecked="{Binding VerifySsl}" Margin="0,0,0,12"/>

                            <WrapPanel>
                                <Button Content="{Binding Loc[install_cert_user]}"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding InstallCertCmd}" Margin="0,0,6,6"/>
                                <Button Content="{Binding Loc[install_cert_sys]}"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding InstallCertMachineCmd}" Margin="0,0,6,6"/>
                                <Button Content="{Binding Loc[toggle_proxy]}"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding ToggleSysProxyCmd}" Margin="0,0,6,6"/>
                                <Button Content="{Binding Loc[export]}"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding ExportLogsCmd}" Margin="0,0,6,6"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="Back to Home" Style="{StaticResource GhostButton}"
                                Command="{Binding SetDashboardSectionCmd}" CommandParameter="home"
                                Padding="16,8" Margin="0,0,8,0"/>
                        <Button Content="{Binding Loc[done]}" Style="{StaticResource PrimaryButton}"
                                Command="{Binding CloseSettingsCmd}" Padding="22,8"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Background="#CC06100C"
              Visibility="{Binding BootStatus, Converter={StaticResource StringToVisible}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding BootStatus}" FontSize="16" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Loc[please_wait]}"
                           Foreground="{StaticResource FgDimBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
