<Window x:Class="MasterRelayVPN.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MasterRelayVPN.ViewModels"
        xmlns:m="clr-namespace:MasterRelayVPN.Models"
        xmlns:svc="clr-namespace:MasterRelayVPN.Services"
        mc:Ignorable="d"
        Title="MasterRelayVPN"
        Width="1000" Height="660"
        MinWidth="900" MinHeight="600"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI"
        FlowDirection="{Binding Loc.FlowDirection}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <!-- Background image with dark overlay (the leafy green PNG). -->
        <Grid>
            <Image Source="/Assets/background.png" Stretch="UniformToFill" Opacity="0.55"/>
            <Rectangle Fill="#B8071610"/>
        </Grid>

        <!-- Main layout -->
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="38" Height="38" CornerRadius="10"
                            Background="{StaticResource AccentBrush}" Margin="0,0,12,0">
                        <TextBlock Text="M" Foreground="#FF062118"
                                   FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="MasterRelayVPN" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock FontSize="11"
                                   Foreground="{StaticResource FgDimBrush}"
                                   Text="{Binding Loc[app_subtitle]}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding ToggleLanguageCmd}" Padding="14,7" Margin="0,0,8,0"
                            Content="{Binding Loc.LanguageButtonLabel}"
                            ToolTip="{Binding Loc[language]}"/>
                    <Button Content="{Binding Loc[settings]}"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding OpenSettingsCmd}" Padding="16,7"/>
                </StackPanel>
            </Grid>

            <!-- Center -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,9,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Style="{StaticResource StatusDot}" Fill="{Binding StatusBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding StatusFriendly}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{Binding StatusBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Grid.Row="1" VerticalAlignment="Center">
                            <Button Content="{Binding HeroLabel}"
                                    Style="{StaticResource HeroButton}"
                                    Command="{Binding StartCmd}"
                                    Visibility="{Binding IsStopped, Converter={StaticResource BoolToVisible}}"/>
                            <Button Content="{Binding HeroLabel}"
                                    Style="{StaticResource HeroButtonStop}"
                                    Command="{Binding StopCmd}"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisible}}"/>
                            <Button Content="..." Style="{StaticResource HeroButton}"
                                    IsEnabled="False"
                                    Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisible}}"/>
                        </Grid>

                        <!-- Health pill — refreshed every second from the backend snapshot. -->
                        <Border Grid.Row="2" CornerRadius="999" Padding="14,5"
                                BorderThickness="1" BorderBrush="{Binding HealthBrush}"
                                Background="#3F0E2218" HorizontalAlignment="Center"
                                Margin="0,12,0,0">
                            <TextBlock Text="{Binding HealthLabel}" Foreground="{Binding HealthBrush}"
                                       FontWeight="SemiBold" FontSize="12"/>
                        </Border>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,12,0,0">
                            <TextBlock Text="{Binding Loc[cert]}" Foreground="{StaticResource FgDimBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding CertStatus}" Foreground="{Binding CertStatusBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBlock Text="{Binding Loc[proxy]}" Foreground="{StaticResource FgDimBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Loc[proxy_off]}"/>
                                        <Setter Property="Foreground" Value="{StaticResource FgDimBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SysProxyOn}" Value="True">
                                                <Setter Property="Text" Value="{Binding Loc[proxy_on]}"/>
                                                <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="9,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,5">
                        <StackPanel>
                            <TextBlock Text="{Binding Loc[download]}" Style="{StaticResource Caption}"/>
                            <TextBlock Text="{Binding SpeedDown}" Style="{StaticResource StatBig}"/>
                            <TextBlock Text="{Binding TotalDown, StringFormat='total {0}'}"
                                       Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,5,0,5">
                        <StackPanel>
                            <TextBlock Text="{Binding Loc[upload]}" Style="{StaticResource Caption}"/>
                            <TextBlock Text="{Binding SpeedUp}" Style="{StaticResource StatBig}"/>
                            <TextBlock Text="{Binding TotalUp, StringFormat='total {0}'}"
                                       Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,5,0,5">
                        <StackPanel>
                            <TextBlock Text="{Binding Loc[requests]}" Style="{StaticResource Caption}"/>
                            <TextBlock Text="{Binding Requests}" Style="{StaticResource StatMed}"/>
                            <TextBlock Text="{Binding Loc[since_start]}" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,5,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Loc[uptime]}" Style="{StaticResource Caption}"/>
                                <TextBlock Text="{Binding Uptime}" Style="{StaticResource StatMed}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Loc[conns]}" Style="{StaticResource Caption}"/>
                                <TextBlock Text="{Binding Connections}" Style="{StaticResource StatMed}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Activity log -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="14,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="100"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding Loc[activity]}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <ComboBox Width="92" Height="26" Margin="0,0,6,0"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding MinLevel}">
                                <ComboBoxItem Content="Debug"   Tag="{x:Static m:LogLevel.Debug}"/>
                                <ComboBoxItem Content="Info"    Tag="{x:Static m:LogLevel.Info}"/>
                                <ComboBoxItem Content="Warning" Tag="{x:Static m:LogLevel.Warning}"/>
                                <ComboBoxItem Content="Error"   Tag="{x:Static m:LogLevel.Error}"/>
                            </ComboBox>
                            <Button Content="{Binding Loc[copy]}"   Style="{StaticResource GhostButton}" Padding="8,3" Margin="6,0,0,0"
                                    Command="{Binding CopyLogsCmd}"/>
                            <Button Content="{Binding Loc[export]}" Style="{StaticResource GhostButton}" Padding="8,3" Margin="4,0,0,0"
                                    Command="{Binding ExportLogsCmd}"/>
                            <Button Content="{Binding Loc[clear]}"  Style="{StaticResource GhostButton}" Padding="8,3" Margin="4,0,0,0"
                                    Command="{Binding ClearLogsCmd}"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Background="#B80B201A" CornerRadius="7"
                            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                        <ListBox x:Name="LogList"
                                 ItemsSource="{Binding LogsView}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.ScrollChanged="LogList_ScrollChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="8,1"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:LogEntry}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Consolas, Cascadia Mono"
                                                   FontSize="11"
                                                   Text="{Binding Time, StringFormat=HH:mm:ss}"
                                                   Foreground="#FF7CAB91" Margin="0,0,8,0"/>
                                        <TextBlock FontFamily="Consolas, Cascadia Mono" FontSize="11"
                                                   Text="{Binding LevelShort}"
                                                   Width="34" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="{x:Static m:LogLevel.Debug}">
                                                            <Setter Property="Foreground" Value="#FF7CAB91"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="{x:Static m:LogLevel.Info}">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentHiBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="{x:Static m:LogLevel.Warning}">
                                                            <Setter Property="Foreground" Value="{StaticResource WarnBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="{x:Static m:LogLevel.Error}">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontFamily="Consolas, Cascadia Mono" FontSize="11"
                                                   Text="{Binding Message}"
                                                   Foreground="{StaticResource FgBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Settings overlay -->
        <Grid Background="#CC04130D"
              Visibility="{Binding SettingsOpen, Converter={StaticResource BoolToVisible}}">
            <Border Style="{StaticResource Card}" Padding="22"
                    Width="600" MaxHeight="600"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding Loc[settings]}" FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!-- Mode -->
                            <TextBlock Text="{Binding Loc[mode]}" Style="{StaticResource Caption}"/>
                            <ComboBox SelectedValue="{Binding Mode}" SelectedValuePath="Content" Margin="0,0,0,12">
                                <ComboBoxItem Content="apps_script"/>
                                <ComboBoxItem Content="google_fronting"/>
                                <ComboBoxItem Content="domain_fronting"/>
                                <ComboBoxItem Content="custom_domain"/>
                            </ComboBox>

                            <!-- Deployment IDs (multi) -->
                            <TextBlock Text="{Binding Loc[deployment_ids]}" Style="{StaticResource Caption}"/>
                            <ItemsControl ItemsSource="{Binding DeploymentIds}" Margin="0,0,0,6">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas"/>
                                            <Button Grid.Column="1" Content="−"
                                                    Style="{StaticResource GhostButton}"
                                                    Padding="0" Width="30" Height="30" Margin="6,0,0,0"
                                                    Command="{Binding DataContext.RemoveDeploymentCmd,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,14"
                                    Style="{StaticResource GhostButton}"
                                    Content="{Binding Loc[add_deployment]}"
                                    Command="{Binding AddDeploymentCmd}"/>

                            <!-- Domain / SNI -->
                            <TextBlock Text="{Binding Loc[front_domain]}" Style="{StaticResource Caption}"/>
                            <TextBox Text="{Binding FrontDomain, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding Loc[custom_sni]}" Style="{StaticResource Caption}"/>
                            <TextBox Text="{Binding CustomSni, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding Loc[worker_host]}" Style="{StaticResource Caption}"/>
                            <TextBox Text="{Binding WorkerHost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding Loc[auth_key]}" Style="{StaticResource Caption}"/>
                            <TextBox Text="{Binding AuthKey, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" Margin="0,0,0,14"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Loc[listen_host]}" Style="{StaticResource Caption}"/>
                                    <TextBox Text="{Binding ListenHost, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding Loc[port]}" Style="{StaticResource Caption}"/>
                                    <TextBox Text="{Binding ListenPort, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>

                            <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0"
                                    Margin="0,8,0,12"/>
                            <TextBlock Text="{Binding Loc[network_tuning]}" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Loc[fragment]}" Style="{StaticResource Caption}"/>
                                    <TextBox Text="{Binding FragmentSize, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding Loc[chunk]}" Style="{StaticResource Caption}"/>
                                    <TextBox Text="{Binding ChunkSize, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{Binding Loc[parallel]}" Style="{StaticResource Caption}"/>
                                    <TextBox Text="{Binding MaxParallel, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>

                            <CheckBox Content="{Binding Loc[use_chunked]}"
                                      IsChecked="{Binding EnableChunked}" Margin="0,0,0,4"/>
                            <CheckBox Content="{Binding Loc[enable_http2]}"
                                      IsChecked="{Binding EnableHttp2}" Margin="0,0,0,4"/>
                            <CheckBox Content="{Binding Loc[verify_ssl]}"
                                      IsChecked="{Binding VerifySsl}" Margin="0,0,0,12"/>

                            <!-- Network presets -->
                            <TextBlock Text="{Binding Loc[presets]}" FontWeight="SemiBold" Margin="0,4,0,8"/>
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <Button Margin="0,0,4,4" Padding="10,8"
                                        Content="{Binding Loc[preset_stealth]}"
                                        Command="{Binding ApplyPresetCmd}"
                                        CommandParameter="stealth">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActivePreset}" Value="stealth">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="#FF062118"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Margin="4,0,0,4" Padding="10,8"
                                        Content="{Binding Loc[preset_balanced]}"
                                        Command="{Binding ApplyPresetCmd}"
                                        CommandParameter="balanced">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActivePreset}" Value="balanced">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="#FF062118"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Margin="0,4,4,0" Padding="10,8"
                                        Content="{Binding Loc[preset_speed]}"
                                        Command="{Binding ApplyPresetCmd}"
                                        CommandParameter="speed">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActivePreset}" Value="speed">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="#FF062118"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Margin="4,4,0,0" Padding="10,8"
                                        Content="{Binding Loc[preset_auto]}"
                                        Command="{Binding ApplyPresetCmd}"
                                        CommandParameter="auto">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActivePreset}" Value="auto">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="#FF062118"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </UniformGrid>

                            <WrapPanel>
                                <Button Content="{Binding Loc[install_cert_user]}"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding InstallCertCmd}" Margin="0,0,6,6"/>
                                <Button Content="{Binding Loc[install_cert_sys]}"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding InstallCertMachineCmd}" Margin="0,0,6,6"/>
                                <Button Content="{Binding Loc[toggle_proxy]}"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding ToggleSysProxyCmd}" Margin="0,0,6,6"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                                Margin="0,14,0,0">
                        <Button Content="{Binding Loc[done]}" Style="{StaticResource PrimaryButton}"
                                Command="{Binding CloseSettingsCmd}" Padding="20,7"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Boot overlay -->
        <Grid Background="#CC04130D"
              Visibility="{Binding BootStatus, Converter={StaticResource StringToVisible}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding BootStatus}" FontSize="16" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Loc[please_wait]}"
                           Foreground="{StaticResource FgDimBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
